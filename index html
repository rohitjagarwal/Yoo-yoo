<!-- Neawake Font -->
<link href="https://fonts.cdnfonts.com/css/neawake" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    min-height:100vh;
    overflow-x:hidden;
    background:
    linear-gradient(135deg,#ffdce8,#ffeef5,#ffd9e6);
    display:flex;
    justify-content:center;
    align-items:center;
    padding:25px 12px;
    position:relative;
    font-family:'Neawake',sans-serif;
}

/* Floating Cute Stickers */

.sticker{
    position:fixed;
    font-size:34px;
    opacity:0.85;
    animation:float 5s infinite ease-in-out;
    z-index:1;
}

.s1{ top:5%; left:6%; }
.s2{ top:15%; right:6%; animation-delay:1s; }
.s3{ bottom:12%; left:7%; animation-delay:2s; }
.s4{ bottom:7%; right:8%; animation-delay:3s; }
.s5{ top:45%; left:2%; animation-delay:2s; }
.s6{ top:50%; right:2%; animation-delay:4s; }

@keyframes float{
    0%{ transform:translateY(0px); }
    50%{ transform:translateY(-14px); }
    100%{ transform:translateY(0px); }
}

/* Letter */

.letter{
    width:100%;
    max-width:760px;
    min-height:92vh;
    background:#fff9f1;
    border-radius:22px;
    padding:35px 24px;
    position:relative;
    z-index:2;
    overflow:hidden;

    box-shadow:
    0 20px 45px rgba(0,0,0,0.18);

    border:1px solid rgba(255,182,193,0.25);
}

/* Vintage texture */

.letter::before{
    content:"";
    position:absolute;
    inset:0;

    background:
    repeating-linear-gradient(
        to bottom,
        transparent,
        transparent 34px,
        rgba(255,182,193,0.14) 35px
    );

    pointer-events:none;
}

.letter::after{
    content:"";
    position:absolute;
    inset:0;

    background:
    radial-gradient(circle at top left,
    rgba(255,220,230,0.25),
    transparent 35%),

    radial-gradient(circle at bottom right,
    rgba(255,210,220,0.2),
    transparent 35%);

    pointer-events:none;
}

/* Decorative corners */

.corner{
    position:absolute;
    width:70px;
    height:70px;
    border-color:#ffb6ca;
    opacity:0.8;
}

.c1{
    top:14px;
    left:14px;
    border-top:4px solid;
    border-left:4px solid;
    border-radius:18px 0 0 0;
}

.c2{
    top:14px;
    right:14px;
    border-top:4px solid;
    border-right:4px solid;
    border-radius:0 18px 0 0;
}

.c3{
    bottom:14px;
    left:14px;
    border-bottom:4px solid;
    border-left:4px solid;
    border-radius:0 0 0 18px;
}

.c4{
    bottom:14px;
    right:14px;
    border-bottom:4px solid;
    border-right:4px solid;
    border-radius:0 0 18px 0;
}

.content{
    position:relative;
    z-index:2;
}

.title{
    text-align:center;
    color:#ff4e8d;
    font-size:42px;
    margin-bottom:28px;
    letter-spacing:2px;
}

.message{
    color:#5d3f47;
    font-size:24px;
    line-height:1.8;
    letter-spacing:1px;
    white-space:pre-wrap;
}

/* Mobile */

@media(max-width:600px){

    body{
        padding:18px 10px;
    }

    .letter{
        padding:28px 18px;
        border-radius:18px;
    }

    .title{
        font-size:32px;
    }

    .message{
        font-size:19px;
        line-height:1.9;
    }

    .sticker{
        font-size:26px;
    }

}

::-webkit-scrollbar{
    width:5px;
}

::-webkit-scrollbar-thumb{
    background:#ff9fbc;
    border-radius:10px;
}

</style>
</head>

